# Postgres. Локально указывает на контейнер из docker-compose.yml
DATABASE_URI=postgres://postgres:postgres@localhost:5432/insurance

# Длинная случайная строка (например: openssl rand -base64 32)
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Публичный адрес приложения
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- Опционально: S3-совместимое хранилище (Cloudflare R2) для картинок/логотипов ---
# Если не заполнено — файлы сохраняются локально в /public/media (только для локальной разработки)
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
