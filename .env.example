# Public application URL used for canonical links, CORS and CSRF checks.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Optional comma-separated extra origins during a staged domain migration.
ADDITIONAL_TRUSTED_ORIGINS=

# Use a long random value in every environment. Never commit the real secret.
PAYLOAD_SECRET=replace-with-at-least-32-random-characters

# PostgreSQL connection string. For Neon, prefer sslmode=verify-full.
DATABASE_URI=postgresql://user:password@host/database?sslmode=verify-full

# Used only by the optional local Docker PostgreSQL service.
POSTGRES_PASSWORD=replace-with-a-strong-database-password

# Optional production email delivery for password resets and account emails.
# Add and verify the sender domain in Resend before enabling these values.
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=no-reply@example.com
EMAIL_FROM_NAME=Trusty

# Optional S3-compatible production storage (for example, Cloudflare R2).
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_ENDPOINT=

# Optional distributed rate limiting for Vercel and multi-instance hosting.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_SALT=
