{
  "name": "insurance-reviews",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npm run generate:types && next build --webpack",
    "start": "next start",
    "lint": "npm run generate:types && tsc --noEmit --incremental false",
    "test": "tsx --test src/**/*.test.ts",
    "payload": "payload",
    "generate:types": "PAYLOAD_CONFIG_BUILD=1 payload generate:types",
    "migrate:create": "payload migrate:create",
    "migrate:status": "payload migrate:status",
    "migrate": "payload migrate",
    "seed": "tsx --env-file=.env src/seed/seed.ts",
    "stats:recalculate": "tsx --env-file=.env src/scripts/recalculateCompanyStats.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "3.86.0",
    "@payloadcms/email-resend": "^3.86.0",
    "@payloadcms/next": "3.86.0",
    "@payloadcms/richtext-lexical": "3.86.0",
    "@payloadcms/storage-s3": "3.86.0",
    "@payloadcms/ui": "3.86.0",
    "graphql": "^16.9.0",
    "next": "^16.2.10",
    "payload": "3.86.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "postcss": "8.5.20",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "yaml": "^2.9.0"
  },
  "overrides": {
    "dompurify": "3.4.12",
    "postcss": "$postcss"
  }
}
